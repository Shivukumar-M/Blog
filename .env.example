# Django Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# MongoDB Atlas Configuration
# For MongoDB Atlas, use your connection string in this format:
# mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/blog_db?retryWrites=true&w=majority
MONGODB_DB_NAME=blog_db

# Example for local MongoDB (development):
# MONGODB_URI=mongodb://localhost:27017/blog_db
# MONGODB_DB_NAME=blog_db

# Cloudinary Configuration (optional, for media storage)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
